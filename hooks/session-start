#!/usr/bin/env bash
# Emits the galdr bootstrap into session context. Silent unless the always-on core is
# enabled. Enablement lives at a STABLE path (~/.claude/galdr/enabled) so it survives
# plugin updates; the legacy in-plugin flag ($dir/enabled) is still honored.
dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
[ -f "$HOME/.claude/galdr/enabled" ] || [ -f "$dir/enabled" ] || exit 0
cat "$dir/bootstrap.md"
